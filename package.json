{
  "name": "@snazzieslab/artifactservecli",
  "version": "1.0.0",
  "description": "Share a file via a terminal QR code — upload to any S3-compatible storage (AWS S3, MinIO, Cloudflare R2, …), or serve it over your local network.",
  "type": "module",
  "bin": {
    "artifactservecli": "dist/index.js"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "s3",
    "upload",
    "qrcode",
    "cli",
    "bun"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SnazziesLab/artifactservecli.git"
  },
  "homepage": "https://github.com/SnazziesLab/artifactservecli#readme",
  "scripts": {
    "check": "tsc --noEmit",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js",
    "prepublishOnly": "tsc --noEmit && bun run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/lib-storage": "^3.1073.0",
    "dotenv": "^16.6.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "bun-types": "latest",
    "typescript": "^6.0.3"
  }
}

{
  "name": "artifactuploadcli",
  "version": "1.0.0",
  "description": "Upload files to Cloudflare R2 and display a QR code in the terminal",
  "type": "module",
  "bin": {
    "artifactuploadcli": "src/index.ts"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/lib-storage": "^3.1073.0",
    "dotenv": "^16.6.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "bun-types": "latest",
    "typescript": "^6.0.3"
  }
}
